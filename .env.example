# Database Configuration
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=endorsement_tracker
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/endorsement_tracker

# API Configuration
ENV=development
API_PORT=8000

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# Scraper Configuration (Optional - for social media scraping)
# INSTAGRAM_ACCESS_TOKEN=your_token_here
# TWITTER_BEARER_TOKEN=your_token_here

# Rate Limiting
SCRAPER_RATE_LIMIT_CALLS=1
SCRAPER_RATE_LIMIT_PERIOD=2
